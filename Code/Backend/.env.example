# Server Configuration
PORT=8000
NODE_ENV=development
BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
PUBLIC_URL=http://localhost:8000

# Supabase Configuration
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI Configuration
OPENAI_API_KEY=
OPENAI_VECTOR_STORE_ID=

# AI Analysis
USE_AI_ANALYSIS=false

# Twilio Configuration
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+19516251343
# Note: Phone numbers are configured in config/twilio-numbers.json for local presence
# TWILIO_PHONE_NUMBER is used as fallback and for backward compatibility

# Resend Email Configuration
RESEND_API_KEY=
EMAIL_FROM=Sun Speed <noreply@sunspeed.com>

# Google OAuth Configuration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Queue Configuration (all in seconds)
QUEUE_SMS_ENABLED=true
QUEUE_VOICE_ENABLED=true
QUEUE_EMAIL_DELAY=60
QUEUE_SMS_DELAY=30
QUEUE_VOICE_DELAY=60
QUEUE_RETRY_DELAY=30
QUEUE_MAX_ATTEMPTS=2
QUEUE_CHECK_INTERVAL=10000

# Live Transfer
LIVE_TRANSFER_NUMBER=951-972-1902

# Voice Provider
# Controls which realtime API powers the AI voice bot.
# Values: 'openai' (default, gpt-4o-realtime) | 'inworld' (Inworld Realtime API w/ Sarah voice)
VOICE_PROVIDER=openai

# Inworld Realtime API (only used when VOICE_PROVIDER=inworld)
# Base64-encoded client_id:client_secret — sent as "Authorization: Basic <key>"
INWORLD_API_KEY=
# TTS model: 'inworld-tts-1.5-max' (top quality) or 'inworld-tts-1.5-mini' (faster/cheaper)
INWORLD_TTS_MODEL=inworld-tts-1.5-max
# Voice name from Inworld playground (e.g. 'Sarah', 'Dennis')
INWORLD_VOICE=Sarah
# LLM routed through Inworld Router — matches OpenAI model IDs
INWORLD_LLM_MODEL=gpt-4o
